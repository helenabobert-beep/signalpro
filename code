// ─── MAIN APP ─────────────────────────────────────────────────────────────────
export default function App() {
  const [activeTab, setActiveTab] = useState('dashboard');
  const [tickers, setTickers] = useState(DEFAULT_TICKERS);
  const [tickerData, setTickerData] = useState({});
  const [activeCF, setActiveCF] = useState(new Set(['Trend','Momentum','Order Flow']));
  const [recs, setRecs] = useState(DEFAULT_RECS);
  const [portfolio, setPortfolio] = useState([]);
  const [refreshing, setRefreshing] = useState(false);

  // modals
  const [tickerModal, setTickerModal] = useState(false);
  const [recModal, setRecModal] = useState(false);
  const [posModal, setPosModal] = useState(false);
  const [newTickerSym, setNewTickerSym] = useState('');
  const [editingRec, setEditingRec] = useState(null);
  const [recForm, setRecForm] = useState({sym:'',name:'',action:'BUY',target:'',reason:''});
  const [posForm, setPosForm] = useState({sym:'',shares:'',buyPrice:''});
  const [nextId, setNextId] = useState(9);

  // load saved data
  useEffect(() => {
    (async () => {
      try {
        const r = await Storage.get('recs'); if(r) setRecs(JSON.parse(r));
        const p = await Storage.get('portfolio'); if(p) setPortfolio(JSON.parse(p));
        const t = await Storage.get('tickers'); if(t) setTickers(JSON.parse(t));
        const n = await Storage.get('nextId'); if(n) setNextId(parseInt(n));
      } catch {}
    })();
  }, []);

  const save = useCallback(async (r,p,t,n) => {
    await Storage.set('recs',JSON.stringify(r));
    await Storage.set('portfolio',JSON.stringify(p));
    await Storage.set('tickers',JSON.stringify(t));
    await Storage.set('nextId',String(n));
  },[]);

  // fetch prices
  const refreshAll = useCallback(async () => {
    const results = {};
    await Promise.all(tickers.map(async sym => {
      const d = await fetchPrice(sym); if(d) results[sym]=d;
    }));
    setTickerData(prev=>({...prev,...results}));
  },[tickers]);

  useEffect(() => { refreshAll(); const t=setInterval(refreshAll,30000); return ()=>clearInterval(t); },[refreshAll]);

  const onRefresh = async () => { setRefreshing(true); await refreshAll(); setRefreshing(false); };

  const toggleCF = (o) => setActiveCF(prev => { const n=new Set(prev); n.has(o)?n.delete(o):n.add(o); return n; });

  // ticker actions
  const addTicker = () => {
    const sym = newTickerSym.trim().toUpperCase();
    if(!sym||tickers.includes(sym)) { setTickerModal(false); return; }
    const t = [...tickers,sym]; setTickers(t); setTickerModal(false); setNewTickerSym('');
    fetchPrice(sym).then(d=>{ if(d) setTickerData(p=>({...p,[sym]:d})); });
    save(recs,portfolio,t,nextId);
  };
  const removeTicker = (sym) => {
    Alert.alert('Remove '+sym,'Remove this ticker?',[
      {text:'Cancel',style:'cancel'},
      {text:'Remove',style:'destructive',onPress:()=>{ const t=tickers.filter(s=>s!==sym); setTickers(t); save(recs,portfolio,t,nextId); }}
    ]);
  };

  // rec actions
  const openAddRec = () => { setEditingRec(null); setRecForm({sym:'',name:'',action:'BUY',target:'',reason:''}); setRecModal(true); };
  const openEditRec = (r) => { setEditingRec(r.id); setRecForm({sym:r.sym,name:r.name,action:r.action,target:r.target||'',reason:r.reason}); setRecModal(true); };
  const saveRec = () => {
    if(!recForm.sym||!recForm.reason) return;
    let r;
    if(editingRec) { r=recs.map(x=>x.id===editingRec?{...x,...recForm}:x); }
    else { r=[...recs,{...recForm,id:nextId,chg:'—',up:true}]; setNextId(n=>{const nn=n+1;return nn;}); }
    setRecs(r); setRecModal(false); save(r,portfolio,tickers,nextId+1);
  };
  const deleteRec = (id) => {
    Alert.alert('Delete','Remove this recommendation?',[
      {text:'Cancel',style:'cancel'},
      {text:'Delete',style:'destructive',onPress:()=>{ const r=recs.filter(x=>x.id!==id); setRecs(r); save(r,portfolio,tickers,nextId); }}
    ]);
  };

  // portfolio actions
  const addPosition = () => {
    const sym=posForm.sym.trim().toUpperCase();
    const shares=parseFloat(posForm.shares);
    const buyPrice=parseFloat(posForm.buyPrice);
    if(!sym||!shares||!buyPrice) return;
    const p=[...portfolio,{sym,shares,buyPrice,id:Date.now()}];
    setPortfolio(p); setPosModal(false); setPosForm({sym:'',shares:'',buyPrice:''});
    save(recs,p,tickers,nextId);
    if(!tickers.includes(sym)) { const t=[...tickers,sym]; setTickers(t); fetchPrice(sym).then(d=>{if(d) setTickerData(prev=>({...prev,[sym]:d}));}); }
  };
  const removePosition = (id) => {
    Alert.alert('Remove position','Delete this holding?',[
      {text:'Cancel',style:'cancel'},
      {text:'Remove',style:'destructive',onPress:()=>{ const p=portfolio.filter(x=>x.id!==id); setPortfolio(p); save(recs,p,tickers,nextId); }}
    ]);
  };

  const TABS = [{id:'dashboard',label:'Dashboard'},{id:'picks',label:'Picks'},{id:'portfolio',label:'Portfolio'},{id:'ai',label:'AI'}];

  return (
    <SafeAreaView style={{flex:1,backgroundColor:C.bg0}}>
      <StatusBar barStyle="light-content" backgroundColor={C.bg0}/>

      {/* HEADER */}
      <View style={{flexDirection:'row',justifyContent:'space-between',alignItems:'center',paddingHorizontal:16,paddingVertical:10,borderBottomWidth:1,borderColor:C.border,backgroundColor:C.bg0}}>
        <Text style={{fontSize:18,fontWeight:'700',color:C.t1,letterSpacing:-.5}}>Signal<Text style={{color:C.accent}}>Pro</Text></Text>
        <View style={{flexDirection:'row',alignItems:'center',gap:5}}>
          <View style={{width:6,height:6,borderRadius:3,backgroundColor:C.accent}}/>
          <Text style={{color:C.t2,fontSize:11}}>{new Date().toLocaleTimeString('en-US',{hour:'2-digit',minute:'2-digit'})}</Text>
        </View>
      </View>

      {/* TABS */}
      <View style={{flexDirection:'row',borderBottomWidth:1,borderColor:C.border,backgroundColor:C.bg1}}>
        {TABS.map(t=>(
          <TouchableOpacity key={t.id} onPress={()=>setActiveTab(t.id)} style={{flex:1,paddingVertical:10,alignItems:'center',borderBottomWidth:2,borderBottomColor:activeTab===t.id?C.accent:'transparent'}}>
            <Text style={{color:activeTab===t.id?C.accent:C.t2,fontSize:12,fontWeight:'600'}}>{t.label}</Text>
          </TouchableOpacity>
        ))}
      </View>

      {/* CONTENT */}
      <View style={{flex:1}}>
        {activeTab==='dashboard' && <DashboardTab tickers={tickers} tickerData={tickerData} onAddTicker={()=>setTickerModal(true)} onRemoveTicker={removeTicker} activeCF={activeCF} onToggleCF={toggleCF}/>}
        {activeTab==='picks' && <PicksTab recs={recs} tickerData={tickerData} onAdd={openAddRec} onEdit={openEditRec} onDelete={deleteRec}/>}
        {activeTab==='portfolio' && <PortfolioTab portfolio={portfolio} tickerData={tickerData} onAdd={()=>setPosModal(true)} onRemove={removePosition}/>}
        {activeTab==='ai' && <AITab activeCF={activeCF} recs={recs} portfolio={portfolio}/>}
      </View>

      {/* ADD TICKER MODAL */}
      <AppModal visible={tickerModal} title="Add ticker" onClose={()=>setTickerModal(false)}>
        <Inp placeholder="Symbol (e.g. AAPL)" value={newTickerSym} onChangeText={v=>setNewTickerSym(v.toUpperCase())} autoCapitalize="characters"/>
        <BtnPrimary title="Add ticker" onPress={addTicker}/>
      </AppModal>

      {/* REC MODAL */}
      <AppModal visible={recModal} title={editingRec?'Edit recommendation':'Add recommendation'} onClose={()=>setRecModal(false)}>
        <View style={{flexDirection:'row',gap:8}}>
          <Inp placeholder="Symbol" value={recForm.sym} onChangeText={v=>setRecForm(p=>({...p,sym:v.toUpperCase()}))} style={{flex:1}} autoCapitalize="characters"/>
          <Inp placeholder="Company name" value={recForm.name} onChangeText={v=>setRecForm(p=>({...p,name:v}))} style={{flex:2}}/>
        </View>
        <View style={{flexDirection:'row',gap:8,marginBottom:10}}>
          {['BUY','SELL','WATCH'].map(a=>(
            <TouchableOpacity key={a} onPress={()=>setRecForm(p=>({...p,action:a}))}
              style={{flex:1,padding:10,borderRadius:10,borderWidth:1,alignItems:'center',
                borderColor:recForm.action===a?C.accent:C.border,
                backgroundColor:recForm.action===a?'rgba(0,229,160,.1)':C.bg2}}>
              <Text style={{color:recForm.action===a?C.accent:C.t2,fontSize:12,fontWeight:'600'}}>{a}</Text>
            </TouchableOpacity>
          ))}
        </View>
        <Inp placeholder="Price target (e.g. $185)" value={recForm.target} onChangeText={v=>setRecForm(p=>({...p,target:v}))}/>
        <Inp placeholder="Reason / analysis..." value={recForm.reason} onChangeText={v=>setRecForm(p=>({...p,reason:v}))} multiline numberOfLines={3} style={{height:80,textAlignVertical:'top'}}/>
        <BtnPrimary title="Save" onPress={saveRec}/>
      </AppModal>

      {/* POSITION MODAL */}
      <AppModal visible={posModal} title="Add position" onClose={()=>setPosModal(false)}>
        <Inp placeholder="Symbol (e.g. NVDA)" value={posForm.sym} onChangeText={v=>setPosForm(p=>({...p,sym:v.toUpperCase()}))} autoCapitalize="characters"/>
        <View style={{flexDirection:'row',gap:8}}>
          <Inp placeholder="Shares" value={posForm.shares} onChangeText={v=>setPosForm(p=>({...p,shares:v}))} keyboardType="decimal-pad" style={{flex:1}}/>
          <Inp placeholder="Buy price ($)" value={posForm.buyPrice} onChangeText={v=>setPosForm(p=>({...p,buyPrice:v}))} keyboardType="decimal-pad" style={{flex:1}}/>
        </View>
        <BtnPrimary title="Add position" onPress={addPosition}/>
      </AppModal>
    </SafeAreaView>
  );
}

const s = StyleSheet.create({
  scroll:{flex:1,paddingHorizontal:12,paddingTop:10},
  recBtn:{paddingHorizontal:12,paddingVertical:5,borderRadius:8,borderWidth:1,borderColor:C.border,backgroundColor:C.bg2},
  disclaimer:{color:C.t3,fontSize:9,textAlign:'center',paddingVertical:12,lineHeight:14},
});
