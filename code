// ─── PORTFOLIO TAB ────────────────────────────────────────────────────────────
function PortfolioTab({portfolio, tickerData, onAdd, onRemove}) {
  let totalVal=0, totalCost=0;
  portfolio.forEach(p => {
    const cur = tickerData[p.sym]?.price ?? p.buyPrice;
    totalVal += p.shares*cur;
    totalCost += p.shares*p.buyPrice;
  });
  const totalPnl = totalVal-totalCost;
  const totalPct = totalCost ? totalPnl/totalCost*100 : 0;

  return (
    <ScrollView style={s.scroll} showsVerticalScrollIndicator={false}>
      <View style={{flexDirection:'row',gap:8,marginBottom:10}}>
        {[
          {label:'Total value', val:fmtMoney(totalVal), sub:(totalPnl>=0?'+':'')+fmtMoney(totalPnl)+' ('+totalPct.toFixed(1)+'%)', color:totalPnl>=0?C.success:C.danger},
          {label:'Positions', val:String(portfolio.length), sub:'holdings', color:C.t2},
        ].map(c => (
          <View key={c.label} style={{flex:1,backgroundColor:C.bg2,borderRadius:10,padding:12}}>
            <Text style={{color:C.t2,fontSize:10,marginBottom:3}}>{c.label}</Text>
            <Text style={{color:C.t1,fontSize:20,fontWeight:'700'}}>{c.val}</Text>
            <Text style={{color:c.color,fontSize:10,marginTop:2}}>{c.sub}</Text>
          </View>
        ))}
      </View>
      <TouchableOpacity onPress={onAdd} style={{flexDirection:'row',alignItems:'center',gap:4,marginBottom:8}}>
        <Text style={{color:C.accent,fontSize:12}}>+ Add position</Text>
      </TouchableOpacity>
      {portfolio.length===0 && <Text style={{color:C.t3,fontSize:12,textAlign:'center',paddingVertical:30}}>No positions yet. Tap + Add position.</Text>}
      {portfolio.map(p => {
        const live = tickerData[p.sym];
        const cur = live?.price ?? p.buyPrice;
        const val = p.shares*cur;
        const cost = p.shares*p.buyPrice;
        const pnl = val-cost;
        const pct = cost ? pnl/cost*100 : 0;
        return (
          <Card key={p.id}>
            <View style={{flexDirection:'row',alignItems:'center',gap:10}}>
              <View style={{width:44,height:44,borderRadius:22,backgroundColor:C.bg3,alignItems:'center',justifyContent:'center'}}>
                <Text style={{color:C.accent,fontSize:12,fontWeight:'700'}}>{p.sym.slice(0,3)}</Text>
              </View>
              <View style={{flex:1}}>
                <Text style={{color:C.t1,fontSize:14,fontWeight:'700'}}>{p.sym}</Text>
                <Text style={{color:C.t2,fontSize:10}}>{p.shares} shares @ ${p.buyPrice.toFixed(2)}</Text>
                {live && <Text style={{color:C.t3,fontSize:10}}>Live: ${fmtPrice(cur)}</Text>}
              </View>
              <View style={{alignItems:'flex-end'}}>
                <Text style={{color:C.t1,fontSize:14,fontWeight:'700'}}>{fmtMoney(val)}</Text>
                <Text style={{color:pnl>=0?C.success:C.danger,fontSize:11}}>{pnl>=0?'+':''}{fmtMoney(pnl)} ({pct>=0?'+':''}{pct.toFixed(1)}%)</Text>
              </View>
              <TouchableOpacity onPress={()=>onRemove(p.id)} style={{paddingLeft:8}}>
                <Text style={{color:C.t3,fontSize:18}}>×</Text>
              </TouchableOpacity>
            </View>
          </Card>
        );
      })}
      <Text style={s.disclaimer}>⚠️ Portfolio tracking is approximate. Prices may be delayed.</Text>
    </ScrollView>
  );
}

